  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@aegisradar.io\",\n  \"password\": \"Demo@1234\"\n}"
            },
            "url": {
              "raw": "http://localhost:5099/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5099",
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Register New Merchant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Test Company\",\n  \"email\": \"test@company.com\",\n  \"password\": \"SecurePass@123\",\n  \"country\": \"EG\"\n}"
            },
            "url": {
              "raw": "http://localhost:5099/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5099",
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        }
      ]
