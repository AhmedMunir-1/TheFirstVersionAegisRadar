      "item": [
        {
          "name": "Submit Transaction (API Key Auth)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "ar_demo_key_aegisradar_2024_secure"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"cust_{{$timestamp}}\",\n  \"amount\": 1500.00,\n  \"currency\": \"EGP\",\n  \"country\": \"EG\",\n  \"mcc\": 5411,\n  \"deviceId\": \"dev_abc123\",\n  \"ipAddress\": \"197.1.2.3\"\n}"
            },
            "url": {
              "raw": "http://localhost:5099/api/transactions",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5099",
              "path": ["api", "transactions"]
            }
          },
          "response": []
        },
        {
