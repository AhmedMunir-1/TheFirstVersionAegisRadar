# AegisRadar Environment Variables
# Copy this file to .env and fill in real values before running docker-compose.
# NEVER commit the .env file to version control.

# ── SQL Server ───────────────────────────────────────────────────────────────
SQL_PASSWORD=AegisRadar@2024!

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=AegisRadar_SuperSecret_JWT_Key_2024_Production_Replace_Me!!

# ── External AI Fraud Detection API ──────────────────────────────────────────
# Set this to the URL of the AI model API you are integrating with.
# The backend will POST the 8 fraud features to: AI_API_URL + AI_API_PREDICT_ENDPOINT
AI_API_URL=http://your-ai-api-host
AI_API_PREDICT_ENDPOINT=/predict
