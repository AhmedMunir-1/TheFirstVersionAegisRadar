{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserver,1433;Database=AegisRadarDATA;User Id=sa;Password=${SQL_PASSWORD};TrustServerCertificate=True;MultipleActiveResultSets=True;Connect Timeout=60;",
    "Redis": "${REDIS_URL:-redis:6379}"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "AegisRadar",
    "Audience": "AegisRadarClients",
    "ExpiryHours": 8
  },
  "Kafka": {
    "BootstrapServers": "${KAFKA_BOOTSTRAP_SERVERS:-kafka:9092}",
    "GroupId": "aegisradar-worker",
    "TransactionsTopic": "aegis-transactions"
  },
  "AiService": {
    "BaseUrl": "${AI_API_URL:-http://localhost:8000}",
    "PredictEndpoint": "${AI_API_PREDICT_ENDPOINT:-/predict}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
